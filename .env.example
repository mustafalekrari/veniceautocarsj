# Copier ce fichier en .env et remplir les valeurs

# Django
SECRET_KEY=venice-autocars-secret-key-change-in-production
DEBUG=True

# Supabase PostgreSQL
# Récupérer depuis : Supabase > Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[MOT_DE_PASSE]@db.[PROJET_ID].supabase.co:5432/postgres

# Optionnel : pour la production
ALLOWED_HOSTS=localhost,127.0.0.1
